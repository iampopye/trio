# ── Python ──────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environments ──────────────────────
venv/
env/
.venv/
trio_env/

